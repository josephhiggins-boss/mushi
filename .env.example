# Mushi: environment configuration
# Copy this file to `.env` (sibling of mushi.py) and fill in your values.
# Mushi reads keys from process env first, then from this file.

# === Required ===

# Bot token from @BotFather. Message @BotFather, /newbot, follow prompts.
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user ID. Only this user is served. Get yours by
# messaging @userinfobot.
TELEGRAM_USER_ID=

# === LLM access (need at least one path) ===

# Recommended: install Claude Code (claude.ai/code) and let mushi invoke
# the `claude` CLI as a subprocess. Routes /think and /cc through your
# subscription instead of burning API credits.
# CLAUDE_CLI=claude

# Anthropic API fallback for /think and /ask. Used when CLAUDE_CLI is
# absent or the CLI call fails. Key at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# OpenAI key for Whisper transcription of Telegram voice messages.
# Optional. Without this, voice messages are ignored.
OPENAI_API_KEY=

# DeepSeek key for cheap /ask and /think fallbacks if Anthropic fails.
# Optional. Key at https://platform.deepseek.com.
DEEPSEEK_API_KEY=

# === Storage (sensible defaults under ~/.claude-bridge/) ===

# Markdown memory folder. Each /remember writes a .md here; Claude reads
# them at the start of every conversation.
# MEMORY_DIR=~/.claude-bridge/memory

# Inbox folder for files / images sent from chat.
# INBOX_DIR=~/.claude-bridge/inbox

# Default working directory for /cc jobs. Override per-chat with /cd.
# BRIDGE_DEFAULT_CWD=~/projects

# === Optional integrations ===

# Comma-separated additional .log files /cost should scan for token-usage
# lines (matches `tokens in=N out=M` near `triage:` or `opus returned`).
# Useful if a sibling agent on the same machine logs its own LLM calls.
# BRIDGE_EXTRA_COST_LOGS=/path/to/agent.log,/path/to/other.log

# JSON ideas-reports folder for the /ideas command. Each file is shaped
# {"reel_id": "...", "ideas": [{"idea": "...", "novelty_score": int,
# "viability_score": int, "weekend_buildable": bool, "stack": [...]}]}
# BRIDGE_IDEAS_DIR=/path/to/ideas

# === Advanced ===

# Set to "0" to disable the Claude CLI integration and force everything
# onto the API path. Default "1" (CLI preferred).
# USE_CLI_FOR_AI=1
